{
   "manifest_version": 3,
   "name": "__MSG_extName__",
   "version": "1.2",
   "description": "__MSG_extDescription__",
   "default_locale": "en",
   "background": {
     "service_worker": "background.js"
   },
   "content_scripts": [
     {
       "all_frames": true,
       "js": ["mouseTrack.js"],
       "matches": ["<all_urls>"],
       "run_at": "document_idle"
     }
   ],
   "permissions": ["tabs", "storage", "activeTab", "sessions"],
   "options_page": "options.html",
   "host_permissions": ["<all_urls>"],
   "icons": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
   },
   "action": {
     "default_popup": "options.html?popup=1",
     "default_icon": {
        "16": "icon-16.png",
        "32": "icon-32.png",
        "48": "icon-48.png",
        "128": "icon-128.png"
     }
   }
 }
