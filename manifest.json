{
  "manifest_version": 3,
  "name": "sBookmarkCleaner",
  "version": "1.0.0",
  "description": "Simple Bookmark Cleaner: Sorts, finds broken links, and identifies duplicates.",
  "permissions": [
    "bookmarks",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
