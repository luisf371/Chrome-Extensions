{
   "manifest_version": 3,
   "name": "sTabControl",
   "version": "1.0",
   "description": "Manage your tabs",
   "icons": {
      "16": "stack.png",
      "48": "stack.png",
      "128": "stack.png"
   },
   "background": {
      "service_worker": "background.js"
   },
   "options_ui": {
      "page": "options.html",
      "open_in_tab": true
   },
   "permissions": [
      "tabs",
      "storage"
   ]
}
