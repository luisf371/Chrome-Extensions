{
   "manifest_version": 3,
   "name": "sGestures",
   "version": "1.0",
   "description": "a simple mouse gestures (sGestures) program with no bloat.",
   "background": {
     "service_worker": "background.js"
   },
   "content_scripts": [
     {
       "all_frames": true,
       "js": ["mouseTrack.js"],
       "matches": ["<all_urls>"],
       "run_at": "document_start"
     }
   ],
   "permissions": ["tabs", "storage", "activeTab"],
   "options_page": "options.html",
   "host_permissions": ["<all_urls>"],
   "action": {
     "default_popup": "options.html"
   }
 }
