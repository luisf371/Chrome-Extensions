{
   "manifest_version": 3,
   "name": "__MSG_extName__",
   "version": "1.0.0",
   "description": "__MSG_extDescription__",
   "default_locale": "en",
   "icons": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
   },
   "background": {
      "service_worker": "background.js"
   },
   "action": {
      "default_title": "__MSG_extName__",
      "default_popup": "options.html?popup=1"
   },
   "options_ui": {
      "page": "options.html",
      "open_in_tab": true
   },
    "permissions": [
       "tabs",
       "storage",
       "webNavigation",
       "scripting"
    ]

}
